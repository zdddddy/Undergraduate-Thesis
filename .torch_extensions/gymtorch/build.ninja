ninja_required_version = 1.3
cxx = /usr/bin/g++-11

cflags = -DTORCH_EXTENSION_NAME=gymtorch -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/zdd/anaconda3/envs/leggedGym/lib/python3.8/site-packages/torch/include -isystem /home/zdd/anaconda3/envs/leggedGym/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -isystem /home/zdd/anaconda3/envs/leggedGym/lib/python3.8/site-packages/torch/include/TH -isystem /home/zdd/anaconda3/envs/leggedGym/lib/python3.8/site-packages/torch/include/THC -isystem /home/zdd/anaconda3/envs/leggedGym/include/python3.8 -D_GLIBCXX_USE_CXX11_ABI=0 -fPIC -std=c++17 -DTORCH_MAJOR=2 -DTORCH_MINOR=4
post_cflags = 
cuda_dlink_post_cflags = 
ldflags = -shared -L/home/zdd/anaconda3/envs/leggedGym/lib/python3.8/site-packages/torch/lib -lc10 -ltorch_cpu -ltorch -ltorch_python

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc



rule link
  command = $cxx $in $ldflags -o $out

build gymtorch.o: compile /home/zdd/RL/IsaacGym_Preview_4_Package/isaacgym/python/isaacgym/_bindings/src/gymtorch/gymtorch.cpp



build gymtorch.so: link gymtorch.o

default gymtorch.so
